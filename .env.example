# AnimePulse Environment Variables
# =====================================
# انسخ هذا الملف: cp .env.example .env.local
# -------------------------------------

# ⚠️ IMPORTANT: غيّر CRON_SECRET قبل الاستخدام!
# استخدم مولد أمني: openssl rand -base64 32
# أو: https://1password.com/password-generator/

# Cloudflare Worker Cron Secret
# الغرض: حماية نقاط نهاية Cron من الوصول غير المصرح به
# يُستخدم في: /auto-pilot?secret=YOUR_SECRET
# لا تشاركه مع أحد!
CRON_SECRET="CHANGE_ME_TO_RANDOM_32_CHARS_STRING"

# =====================================
# 🔥 Firebase Configuration
# احصل عليها من: https://console.firebase.google.com
# ------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# =====================================
# 📱 Telegram Bot Configuration
# 1. أنشئ بوت عبر @BotFather
# 2. احصل على التوكن
# 3. أضف البوت لقناتك وأعطِه admin
# ------------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here

# =====================================
# 🤖 Google Gemini AI
# احصل على API Key من: https://makersuite.google.com/app/apikey
# ------------------------------------
GEMINI_API_KEY=your_gemini_api_key

# =====================================
# 🌐 App Settings
# ------------------------------------
NEXT_PUBLIC_APP_URL=https://animepulse.pages.dev

# =====================================
# 💰 Google AdSense (اختياري)
# ------------------------------------
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxx

# =====================================
# 🔒 SECURITY NOTES
# =====================================
# 1. NEVER commit .env.local to Git!
# 2. Regularly rotate API keys
# 3. Use strong CRON_SECRET (32+ chars)
# 4. Restrict Telegram bot to specific chat
# 5. Monitor Firebase usage for abuse
