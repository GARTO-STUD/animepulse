# ============================================================
# AnimePulse — Environment Variables
# Copy this file: cp .env.example .env.local
# ============================================================

# ── Cron Secret ─────────────────────────────────────────────
# Protects /api/autopilot from unauthorized calls
# Generate: openssl rand -base64 32
CRON_SECRET=CHANGE_ME_TO_RANDOM_32_CHARS

# ── Gemini AI ────────────────────────────────────────────────
# Get free key: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key

# ── App URL ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://animepulse.online

# ── Firebase (Client SDK) ────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ── Firebase Admin (Server SDK) ──────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts
# → Generate New Private Key → copy the ENTIRE JSON as one line
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ── Google AdSense (optional) ────────────────────────────────
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxx

# ============================================================
# SECURITY NOTES
# ============================================================
# 1. NEVER commit .env.local to Git
# 2. Add .env.local to .gitignore (already included)
# 3. Rotate CRON_SECRET regularly
# 4. FIREBASE_SERVICE_ACCOUNT_KEY must be on ONE line (no line breaks)
